{
  "singleQuote": true,
  "tabWidth": 4,
  "trailingComma": "none",
  "useTabs": true,
  "plugins": ["prettier-plugin-apex", "@prettier/plugin-xml"],
  "printWidth": 120,
  "overrides": [
    {
      "files": "**/lwc/**/*.html",
      "options": { "parser": "lwc", "tabWidth": 4 }
    },
    {
      "files": "*.{cmp,page,component}",
      "options": {
        "parser": "html"
      }
    },
    {
      "files": "**/*.{cls,trigger,apex}",
      "options": { "parser": "apex", "tabWidth": 4, "printWidth": 140 }
    }
  ]
}
